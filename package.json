{
  "name": "mantine-vite-template",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "npm run oxlint && npm run stylelint",
    "oxlint": "oxlint .",
    "stylelint": "stylelint '**/*.css' --cache",
    "format:test": "oxfmt --check \"**/*.{ts,tsx,css}\"",
    "format:write": "oxfmt --write \"**/*.{ts,tsx,css}\"",
    "vitest": "vitest run",
    "vitest:watch": "vitest",
    "test": "npm run typecheck && npm run format:test && npm run lint && npm run vitest && npm run build",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@mantine/carousel": "^9.0.0",
    "@mantine/charts": "^9.0.0",
    "@mantine/code-highlight": "^9.0.0",
    "@mantine/core": "^9.0.0",
    "@mantine/dates": "^9.0.0",
    "@mantine/dropzone": "^9.0.0",
    "@mantine/form": "^9.0.0",
    "@mantine/hooks": "^9.0.0",
    "@mantine/modals": "^9.0.0",
    "@mantine/notifications": "^9.0.0",
    "@mantine/nprogress": "^9.0.0",
    "@mantine/spotlight": "^9.0.0",
    "@mantine/tiptap": "^9.0.0",
    "@tabler/icons-react": "^3.41.1",
    "@tiptap/extension-link": "^3.22.1",
    "@tiptap/pm": "^3.22.1",
    "@tiptap/react": "^3.22.1",
    "@tiptap/starter-kit": "^3.22.1",
    "dayjs": "^1.11.20",
    "embla-carousel": "^8.5.2",
    "embla-carousel-react": "^8.5.2",
    "plotly.js": "^3.4.0",
    "plotly.js-dist-min": "^3.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^7.9.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@storybook/addon-themes": "^10.0.0",
    "@storybook/react": "^10.0.0",
    "@storybook/react-vite": "^10.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@types/react-plotly.js": "^2.6.4",
    "@vitejs/plugin-react": "^6.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^29.0.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.58.0",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prop-types": "^15.8.1",
    "storybook": "^10.0.0",
    "stylelint": "^17.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "packageManager": "yarn@4.13.0"
